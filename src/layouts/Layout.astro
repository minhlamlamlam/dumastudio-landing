---
import DarkModeToggle from '../components/DarkModeToggle.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: 'fr' | 'en';
}

const { title, description, lang = 'fr' } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const altHref = lang === 'fr' ? '/en' : '/';
const altLabel = lang === 'fr' ? 'EN' : 'FR';
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/dumastudio-logo-transp.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/dumastudio-logo-transp.png', Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL('/dumastudio-logo-transp.png', Astro.site)} />

    <!-- Preload critical assets -->
    <link rel="preload" href="/dumastudio-logo-transp.png" as="image" />
  </head>
  <body class="min-h-screen">
    <DarkModeToggle />
    <a
      href={altHref}
      class="fixed top-6 right-20 p-3 rounded-full bg-gray-100 dark:bg-gray-900 hover:bg-gray-200 dark:hover:bg-gray-800 transition-all duration-300 z-50 w-11 h-11 flex items-center justify-center font-semibold text-sm text-gray-800 dark:text-gray-200 backdrop-blur-sm"
      aria-label={`Switch to ${altLabel}`}
    >
      {altLabel}
    </a>
    <slot />
  </body>
</html>
